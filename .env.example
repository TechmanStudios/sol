# SOL RSI — Environment Variables Template
# Copy this file to .env and fill in your token.
# .env is gitignored — secrets stay local.

# GitHub Models API token (fine-grained PAT with Models access)
# Used as fallback when OPENAI_API_KEY is not set.
GITHUB_TOKEN=github_pat_XXXXXXXXXXXXXXXXXXXX

# OpenAI Direct API key — preferred provider for GPT-5.4 family
# Enables: gpt-5.4 (reasoning slot), gpt-5.4-mini (primary), gpt-5.4-nano (lightweight)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Optional GitHub token overrides
# GITHUB_MODELS_TOKEN=
# GH_TOKEN=
